APP_NAME=Accessible E-Learning API
ENV=production
DEBUG=false

# Railway PostgreSQL
# Use the private DATABASE_URL from Railway when the API and DB are in the same project.
# Public URL format also works, for example:
# postgresql://postgres:password@host:port/railway
DATABASE_URL=postgresql://postgres:password@host:port/railway
# Alternative if Railway exposes individual variables to this service:
# PGHOST=host
# PGPORT=5432
# PGDATABASE=railway
# PGUSER=postgres
# PGPASSWORD=password

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALG=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
AUTO_CREATE_TABLES=true

# CORS
# Use * while deploying/testing, or replace with your frontend origin later.
CORS_ORIGINS=*
